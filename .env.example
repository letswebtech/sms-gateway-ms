# SMS Gateway Microservice – environment variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Security – any string shared with your other backend services
API_SECRET_KEY=your-secret-key-here

# Firebase Admin SDK – download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gateway device – FCM token of the Flutter SMS gateway app
# Update this whenever the gateway app re-registers (handled via /register endpoint)
GATEWAY_FCM_TOKEN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Delivery callback timeout (ms) – how long to wait for the app to confirm SMS sent
DELIVERY_TIMEOUT_MS=30000
